# ========================================
# MySocialDesktop - .gitignore
# ========================================

# --- Build artifacts (C++) ---
build_cpp/
build/

# --- UI dependencies and build cache ---
ui-src/node_modules/
ui-src/.vite/
ui-src/dist/


# --- Debug and log files ---
*.log
debug.log

# --- WebView2 user data (browser cache, cookies, etc.) ---
*.exe.WebView2/

# --- Compiled binaries ---
*.exe
*.dll
*.obj
*.o
*.pdb
*.ilk
*.lib
*.exp

# --- IDE and OS files ---
.vs/
.vscode/
ui-src/.vscode/
.idea/
*.suo
*.user
*.sln.docstates
.DS_Store
Thumbs.db
desktop.ini

# --- Environment variables ---
.env
.env.*

# --- CMake generated ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# --- NuGet packages (fetched by CMake) ---
_deps/

# --- Temporary and agent files ---
AGENTS.md
CLAUDE.md

# --- Release artifacts (uploaded separately) ---
*.zip
release-package/
